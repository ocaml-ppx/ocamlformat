(* basic syntax *)

let idx_r () = (.foo)
let idx_r_r () = (.foo.#foo)
let idx_array x = (.(x))
let idx_array_L x = (.L(x))
let idx_array_l x = (.l(x))
let idx_array_S x = (.S(x))
let idx_array_s x = (.s(x))
let idx_array_n x = (.n(x))
let idx_iarray x = (.:(x))
let idx_iarray_L x = (.:L(x))
let idx_iarray_l x = (.:l(x))
let idx_iarray_S x = (.:S(x))
let idx_iarray_s x = (.:s(x))
let idx_iarray_n x = (.:n(x))
let idx_imm x = (.idx_imm(x))
let idx_mut x = (.idx_mut(x))

(* long chains *)

let idx_r () =
  (.Foo.Bar.baz1234567890
   .#Foo.Bar.baz1234567890
   .#Foo.Bar.baz1234567890
   .#Foo.Bar.baz1234567890
   .#Foo.Bar.baz1234567890
   .#Foo.Bar.baz1234567890
   .#Foo.Bar.baz1234567890
   .#Foo.Bar.baz1234567890
   .#Foo.Bar.baz1234567890
   .#Foo.Bar.baz1234567890
   .#Foo.Bar.baz1234567890)
;;

